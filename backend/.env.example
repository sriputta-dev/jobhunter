# ============================================================
# JobHunter Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── AI Analysis (Required for resume tailoring + cold email + strategy) ──────
# Get your key: console.anthropic.com → Sign Up → API Keys → Create Key
# New accounts get $5 free credits (~100+ job analyses)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Job Search: LinkedIn + Indeed + Dice + Glassdoor + ZipRecruiter ──────────
# JSearch API via RapidAPI — covers ALL major job boards in one API key
# How to get (free):
#   1. Go to rapidapi.com → Sign Up (free, 30 seconds)
#   2. Search "JSearch" in the marketplace
#   3. Click Subscribe → choose Free plan (200 requests/month free)
#   4. Go to Endpoints tab → copy the X-RapidAPI-Key value
# Free tier: 200 req/month | Paid: $10/month for 500 req
# Without this key: system still works using 5 free sources (Himalayas, Remotive, etc.)
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./jobhunter.db

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
